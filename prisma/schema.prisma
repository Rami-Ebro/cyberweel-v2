generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PARTNER
  CLIENT
}

enum PartnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ReferralStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(CLIENT)
  partner   Partner?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id             String          @id @default(cuid())
  referralNumber Int             @unique @default(autoincrement())
  status         PartnerStatus   @default(PENDING)
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals      PartnerReferral[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

model PartnerReferral {
  id          String         @id @default(cuid())
  partnerId   String
  partner     Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name        String?
  email       String?
  phone       String?
  status      ReferralStatus @default(NEW)
  sourcePath  String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([partnerId])
  @@index([partnerId, status])
  @@index([createdAt])
}

model SmartLink {
  id             String          @id @default(cuid())
  title          String
  slug           String          @unique
  destinationUrl String
  isActive       Boolean         @default(true)
  redirectType   String          @default("TEMPORARY")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scans          SmartLinkScan[]
}

model SmartLinkScan {
  id          String    @id @default(cuid())
  smartLinkId String
  link        SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)
  scannedAt   DateTime  @default(now())
  ipHash      String?
  country     String?
  city        String?
  device      String?
  os          String?
  browser     String?
  userAgent   String?
  referer     String?
  createdAt   DateTime  @default(now())

  @@index([smartLinkId])
  @@index([scannedAt])
}
