# Owner-only admin authentication.
# Copy to .env.local and fill with real values. NEVER commit real secrets.

# The single owner's login email.
ADMIN_OWNER_EMAIL=owner@example.com

# scrypt password hash, format: <salt-hex>:<scrypt-hash-hex> (64-byte scrypt).
# Generate locally:
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" 'your-password'
ADMIN_OWNER_PASSWORD_HASH=salt-hex:scrypt-hash-hex

# Random session-signing secret, minimum 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value immediately invalidates all existing sessions.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string-of-32-plus-chars
